    box-shadow: 0 34px 120px rgba(0, 0, 0, 0.42);
}

.vr-lightbox-media {
    min-height: 520px;
    background: #000;
}

.vr-lightbox-media img,
.vr-lightbox-media video {
    width: 100%;
    height: 100%;
    max-height: min(760px, calc(100svh - 48px));
