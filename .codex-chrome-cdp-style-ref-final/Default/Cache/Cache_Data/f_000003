    line-height: 1.15;
}

.contact-section {
    position: relative;
    overflow: hidden;
    display: grid;
    min-height: 78svh;
    grid-template-columns: 1fr auto;
    gap: 28px;
    align-items: end;
    padding: 112px max(24px, calc((100vw - 1120px) / 2));
    background: var(--accent);
    color: var(--ink);
    isolation: isolate;
}

.contact-section::after {
    position: absolute;
    left: 0;
    bottom: 22px;
    z-index: -1;
    color: rgba(16, 16, 16, 0.16);
    content: "CREATE / CREATE / CREATE / CREATE";
    font-size: 6rem;
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
    animation: stripMove 22s linear infinite;
}

.contact-section h2 {
    width: min(800px, 100%);
}

.contact-link {
    display: inline-flex;
    min-width: 148px;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 900;
    text-transform: uppercase;
}

.site-footer {
    display: flex;
    justify-content: space-between;
    padding: 22px 24px;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.64);
