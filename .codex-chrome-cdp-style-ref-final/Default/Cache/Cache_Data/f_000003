/* Compact VR portfolio: one-screen section with clickable project previews. */
.vr-section {
    display: grid;
    grid-template-columns: minmax(340px, 0.88fr) minmax(560px, 1.12fr);
    align-items: center;
    gap: clamp(34px, 4.6vw, 70px);
    min-height: 100svh;
    padding: clamp(56px, 6.5svh, 74px) max(64px, calc((100vw - 1340px) / 2)) clamp(74px, 8svh, 92px);
}

.vr-heading {
    position: relative;
    z-index: 2;
    display: flex;
    max-width: 560px;
    flex-direction: column;
    gap: clamp(18px, 2.8svh, 28px);
    margin: 0;
}

.vr-heading h2 {
    max-width: 560px;
    color: var(--ink);
    font-size: clamp(3.6rem, 5.55vw, 5.85rem);
    line-height: 0.88;
    text-wrap: balance;
}

.vr-heading > p:not(.eyebrow) {
    max-width: 500px;
    color: rgba(8, 10, 18, 0.68);
    font-size: clamp(0.98rem, 1.08vw, 1.08rem);
    line-height: 1.55;
}

.vr-skillline {
    display: flex;
    max-width: 500px;
    flex-wrap: wrap;
    gap: 8px;
}

.vr-skillline span {
    border: 1px solid rgba(41, 71, 255, 0.22);
    border-radius: 999px;
    padding: 9px 12px;
    background: rgba(41, 71, 255, 0.08);
    color: rgba(8, 10, 18, 0.72);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
}

.vr-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(210px, 0.66fr);
    gap: 12px;
    margin: 0;
}

.vr-card {
    min-height: clamp(112px, 13svh, 138px);
    cursor: pointer;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.vr-card:hover,
.vr-card:focus-visible {
    border-color: rgba(41, 71, 255, 0.55);
    box-shadow: 0 24px 70px rgba(41, 71, 255, 0.12);
    outline: none;
    transform: translateY(-4px);
}

.vr-card-large {
    min-height: clamp(400px, 54svh, 520px);
}

.vr-card img {
    position: absolute;
    inset: 0;
    min-height: 0;
}

.vr-card div {
    padding: clamp(14px, 1.7vw, 20px);
}

.vr-card span {
    margin-bottom: 9px;
    padding: 6px 10px;
    font-size: 0.64rem;
}

.vr-card h3 {
    font-size: clamp(1.55rem, 2.2vw, 2rem);
}

.vr-card:not(.vr-card-large) h3 {
    font-size: 1.22rem;
}

.vr-card p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: 0.88rem;
    line-height: 1.35;
}

.vr-section .section-end-cta {
    position: absolute;
    top: auto;
    right: max(64px, calc((100vw - 1340px) / 2));
    bottom: clamp(22px, 3.2svh, 34px);
    left: auto;
    width: max-content;
    margin: 0;
}

.vr-lightbox {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: grid;
    place-items: center;
    padding: 24px;
    background: rgba(8, 10, 18, 0.78);
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
}

.vr-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
}

.vr-lightbox-panel {
    position: relative;
    display: grid;
    width: min(1120px, 100%);
    max-height: min(760px, calc(100svh - 48px));
    grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.75fr);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    background: var(--ink);
