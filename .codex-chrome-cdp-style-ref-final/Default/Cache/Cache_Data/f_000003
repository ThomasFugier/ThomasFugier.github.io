@keyframes craftTitleEcho {
    0%,
    32%,
    100% {
        clip-path: inset(0 100% 0 0);
        opacity: 0;
    }

    44%,
    62% {
        clip-path: inset(0 0 0 0);
        opacity: 1;
    }

    76% {
        clip-path: inset(0 0 0 100%);
        opacity: 0;
    }
}

@keyframes craftTitleMarker {
    0%,
    28%,
