.craft-grid {
    z-index: 3;
}

/* EOF redesign: editorial process board, less pitch-deck, more production system. */
.craft-section {
    position: relative;
    display: grid;
    min-height: 100svh;
    grid-template-columns: minmax(300px, 0.78fr) minmax(560px, 1.05fr);
    grid-template-areas:
        "heading process"
        "cta process";
    align-items: center;
    column-gap: clamp(54px, 8vw, 132px);
    row-gap: clamp(24px, 4svh, 42px);
    padding: clamp(76px, 8svh, 112px) max(44px, calc((100vw - 1320px) / 2)) clamp(76px, 8svh, 112px);
    overflow: hidden;
    background:
        linear-gradient(90deg, rgba(41, 71, 255, 0.18), transparent 34%),
        linear-gradient(180deg, #08090d 0%, #101010 100%);
    color: var(--white);
    isolation: isolate;
}

.craft-section::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
        linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    content: "";
    opacity: 0.58;
    pointer-events: none;
}

.craft-section::after {
    position: absolute;
    right: max(32px, calc((100vw - 1320px) / 2));
    bottom: clamp(34px, 5svh, 64px);
    z-index: -1;
    color: rgba(255, 255, 255, 0.055);
    content: "HOOK / BUILD / READ / SCALE";
    font-size: clamp(2.8rem, 7vw, 7rem);
    font-weight: 900;
    line-height: 0.8;
    pointer-events: none;
}

.craft-section .section-heading.compact {
    grid-area: heading;
    display: grid;
    width: 100%;
    max-width: 560px;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3.4svh, 38px);
    align-self: end;
    justify-self: start;
    margin: 0;
    padding: 0;
}

.craft-section .section-heading .eyebrow,
.craft-section .section-heading .eyebrow span {
    color: var(--blue);
}

.craft-section .section-heading .eyebrow {
    display: inline-grid;
    width: fit-content;
    max-width: 100%;
    margin: 0;
    font-size: 0.82rem;
    line-height: 1;
    text-align: left;
    text-shadow: none;
}

.craft-section .section-heading .eyebrow::after {
    display: block;
    width: 100%;
    height: 3px;
    margin-top: 8px;
    background: var(--blue);
}

.craft-section .section-heading h2,
#craft-title {
    display: block;
    max-width: 560px;
    color: var(--white);
    font-size: clamp(4rem, 6.5vw, 7.25rem);
    line-height: 0.82;
    text-align: left;
    text-shadow: none;
}

#craft-title span {
    display: block;
    width: auto;
    max-width: 100%;
    color: var(--white);
}

#craft-title span:nth-child(2) {
    margin-left: clamp(18px, 4vw, 70px);
}

#craft-title span::before,
#craft-title span::after {
    content: none;
    animation: none;
}

.craft-grid {
    position: relative;
    grid-area: process;
    display: grid;
    width: min(760px, 100%);
    max-width: 760px;
    min-height: 0;
    grid-template-columns: 1fr;
    gap: 0;
    align-self: center;
    justify-self: end;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.28);
    border-bottom: 1px solid rgba(255, 255, 255, 0.28);
    border-left: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(8, 9, 13, 0.28);
    backdrop-filter: blur(10px);
    z-index: 2;
}

.craft-grid::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 71px;
    width: 1px;
    background: rgba(41, 71, 255, 0.55);
    content: "";
}

.craft-grid::after {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--blue), var(--acid), transparent);
    content: "";
    opacity: 0.85;
    transform: translateY(-1px);
    animation: processScan 5.2s ease-in-out infinite;
}

.craft-grid article,
.craft-grid article:first-child,
.craft-grid article:nth-child(1),
.craft-grid article:nth-child(2),
.craft-grid article:nth-child(3),
.craft-grid article:nth-child(4) {
    position: relative;
    display: grid;
    min-height: clamp(112px, 15svh, 148px);
    grid-template-columns: 72px minmax(160px, 0.54fr) minmax(240px, 0.86fr);
    gap: clamp(18px, 2.5vw, 32px);
    align-items: center;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 0;
    padding: clamp(20px, 2.2vw, 30px) 0 clamp(20px, 2.2vw, 30px) clamp(18px, 1.8vw, 24px);
    overflow: hidden;
    background: transparent;
    box-shadow: none;
    color: var(--white);
    backdrop-filter: none;
    transform: none;
    transition: background-color 220ms ease, padding-left 220ms ease, color 220ms ease;
}

.craft-grid article:last-child {
    border-bottom: 0;
}

.craft-grid article::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    height: auto;
    background: var(--blue);
    content: "";
    opacity: 0.95;
    transform: none;
    transition: width 220ms ease;
}

.craft-grid article::after {
    content: none;
}

.craft-grid article.is-visible,
.craft-grid article:hover,
.craft-grid article:nth-child(1).is-visible,
.craft-grid article:nth-child(1):hover,
.craft-grid article:nth-child(2).is-visible,
.craft-grid article:nth-child(2):hover,
.craft-grid article:nth-child(3).is-visible,
.craft-grid article:nth-child(3):hover,
.craft-grid article:nth-child(4).is-visible,
.craft-grid article:nth-child(4):hover {
    background: rgba(41, 71, 255, 0.12);
    box-shadow: none;
    transform: none;
}

.craft-grid article:hover {
    padding-left: clamp(26px, 2.6vw, 38px);
}

.craft-grid article:hover::before {
    width: 4px;
}

.craft-grid span {
    display: block;
    width: auto;
    height: auto;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--blue);
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    opacity: 1;
}

.craft-grid h3 {
    max-width: 250px;
    margin: 0;
    color: var(--white);
    font-size: clamp(1.35rem, 1.8vw, 2rem);
    line-height: 0.98;
}

.craft-grid p {
    max-width: 360px;
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: clamp(0.9rem, 0.96vw, 1rem);
    line-height: 1.42;
    opacity: 1;
}

.craft-section > .scene-cta {
    grid-area: cta;
    position: static;
    align-self: start;
    justify-self: start;
    width: max-content;
    max-width: 100%;
    margin: 0;
    background: rgba(255, 255, 255, 0.94);
    color: var(--ink);
}

.craft-section > .scene-cta:hover {
    background: var(--blue);
    border-color: var(--blue);
    color: var(--white);
}

@keyframes processScan {
    0%,
    100% {
        transform: translateY(-1px) scaleX(0.18);
        transform-origin: left center;
        opacity: 0.38;
    }

    45%,
    62% {
        transform: translateY(-1px) scaleX(1);
        opacity: 0.9;
    }

    82% {
        transform: translateY(-1px) scaleX(0);
        transform-origin: right center;
        opacity: 0.2;
    }
}

@media (max-width: 980px) {
    .craft-section {
        min-height: auto;
        grid-template-columns: 1fr;
        grid-template-areas:
            "heading"
            "process"
            "cta";
        row-gap: 36px;
        padding: 82px 24px 118px;
    }

    .craft-section .section-heading.compact,
    .craft-grid {
        width: min(720px, 100%);
        max-width: none;
        justify-self: center;
    }

    .craft-section .section-heading h2,
    #craft-title {
        font-size: clamp(3.2rem, 10vw, 5.6rem);
    }

    .craft-grid article,
    .craft-grid article:first-child,
    .craft-grid article:nth-child(1),
    .craft-grid article:nth-child(2),
    .craft-grid article:nth-child(3),
    .craft-grid article:nth-child(4) {
        grid-template-columns: 56px minmax(0, 1fr);
        gap: 16px;
        padding-right: 0;
    }

    .craft-grid::before {
        left: 55px;
    }

    .craft-grid p {
        grid-column: 2;
        max-width: 520px;
    }

    .craft-section > .scene-cta {
        justify-self: center;
    }
}

@media (max-width: 680px) {
    .craft-section {
        padding: 72px 24px 112px;
    }

    #craft-title span:nth-child(2) {
        margin-left: 0;
    }

    .craft-grid article,
    .craft-grid article:first-child,
    .craft-grid article:nth-child(1),
    .craft-grid article:nth-child(2),
    .craft-grid article:nth-child(3),
    .craft-grid article:nth-child(4) {
        min-height: 0;
        grid-template-columns: 44px minmax(0, 1fr);
        padding-top: 22px;
        padding-bottom: 22px;
    }

    .craft-grid::before {
        left: 43px;
    }

    .craft-grid h3 {
        font-size: 1.24rem;
    }

    .craft-grid p {
        font-size: 0.92rem;
    }

    .craft-section > .scene-cta {
        width: 100%;
        justify-self: stretch;
    }
}

