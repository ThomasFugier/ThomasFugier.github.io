/* Animated black title treatment: echo layer + moving marker for the creative process hook. */
#craft-title {
    position: relative;
    display: grid;
    justify-items: end;
    isolation: isolate;
}

#craft-title span {
    position: relative;
    display: block;
    width: max-content;
    max-width: 100%;
    overflow: visible;
}

#craft-title span:nth-child(2) {
    margin-left: clamp(28px, 4vw, 78px);
}

#craft-title span::before {
    position: absolute;
    z-index: -2;
    inset: 0;
    color: rgba(41, 71, 255, 0.18);
    content: attr(data-text);
    pointer-events: none;
    transform: translate(0.075em, 0.075em);
    clip-path: inset(0 100% 0 0);
    animation: craftTitleEcho 5.8s cubic-bezier(0.7, 0, 0.2, 1) infinite;
}

#craft-title span::after {
    position: absolute;
    z-index: -1;
    right: -0.04em;
    bottom: 0.04em;
    left: -0.04em;
    height: 0.2em;
    background: linear-gradient(90deg, rgba(41, 71, 255, 0.3), rgba(41, 71, 255, 0.05));
    content: "";
    opacity: 0.75;
    transform: scaleX(0.16);
    transform-origin: left center;
    animation: craftTitleMarker 5.8s cubic-bezier(0.7, 0, 0.2, 1) infinite;
}

#craft-title span:nth-child(2)::before,
#craft-title span:nth-child(2)::after {
    animation-delay: 0.22s;
}

.chapter.is-current #craft-title span {
    animation: craftTitleSettle 640ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.chapter.is-current #craft-title span:nth-child(2) {
    animation-delay: 90ms;
}

@keyframes craftTitleEcho {
    0%,
    32%,
    100% {
        clip-path: inset(0 100% 0 0);
        opacity: 0;
    }

    44%,
    62% {
        clip-path: inset(0 0 0 0);
        opacity: 1;
    }

    76% {
        clip-path: inset(0 0 0 100%);
        opacity: 0;
    }
}

@keyframes craftTitleMarker {
    0%,
    28%,
    100% {
        transform: scaleX(0.16);
        opacity: 0.35;
    }

    48%,
    66% {
        transform: scaleX(1);
        opacity: 0.85;
    }

    78% {
        transform: scaleX(0);
        opacity: 0;
        transform-origin: right center;
    }
}

@keyframes craftTitleSettle {
    from {
        opacity: 0;
        transform: translateY(18px) skewY(-2deg);
    }

    to {
        opacity: 1;
        transform: translateY(0) skewY(0);
    }
}

@media (max-width: 980px) {
    #craft-title {
        justify-items: start;
