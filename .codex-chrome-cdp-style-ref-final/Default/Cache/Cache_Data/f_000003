:root {
    --ink: #101010;
    --paper: #f4f0e8;
    --paper-soft: #e9e1d5;
    --muted: #72695e;
    --line: rgba(16, 16, 16, 0.14);
    --white: #ffffff;
    --charcoal: #151413;
    --accent: #e85b2d;
    --acid: #c9ff46;
    --blue: #2947ff;
    --scene: #c9ff46;
    --chapter-accent: #c9ff46;
    --hero-shift: 0px;
    --hero-zoom: 1;
    --reel-shift: 0px;
    --reel-zoom: 1;
    --shadow: 0 24px 80px rgba(16, 16, 16, 0.18);
}

* {
    box-sizing: border-box;
}

html {
    overflow-x: clip;
    scroll-behavior: smooth;
}

body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: Inter, "Helvetica Neue", Arial, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    overflow-x: clip;
}

img,
iframe {
    display: block;
    max-width: 100%;
}

a {
    color: inherit;
    text-decoration: none;
}

button {
    font: inherit;
}

.scroll-meter {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    height: 3px;
    background: transparent;
    pointer-events: none;
}

.scroll-meter span {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--chapter-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: background-color 220ms ease;
}

.scene-cta {
    position: absolute;
    right: 18px;
    bottom: 28px;
    z-index: 16;
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.36);
    border-radius: 8px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.2);
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    backdrop-filter: blur(16px);
    transition: transform 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
}

.scene-cta::after {
    margin-left: 10px;
    content: "\2192";
    opacity: 0.72;
}

.scene-cta:hover {
    background: var(--blue);
    border-color: var(--blue);
    color: var(--white);
    transform: translateY(-2px);
}

.scene-cta-dark {
    background: rgba(8, 10, 18, 0.86);
    color: var(--white);
}

.hero-cta {
    bottom: 32px;
}

.cinema-skip {
    right: 18px;
    bottom: 28px;
}

@media (min-width: 1288px) {
    .scene-cta,
    .cinema-skip {
        right: calc((100vw - 1240px) / 2);
    }
}

.site-nav {
    position: fixed;
    top: 16px;
    left: 50%;
    z-index: 35;
    display: flex;
    width: min(1240px, calc(100% - 32px));
    min-height: 58px;
    align-items: center;
    justify-content: space-between;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    padding: 7px 8px 7px 18px;
    background: rgba(8, 10, 18, 0.62);
    box-shadow: 0 18px 70px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(18px);
    transform: translateX(-50%);
    color: var(--white);
    mix-blend-mode: normal;
    transition:
        min-height 220ms ease,
        padding 220ms ease,
        transform 260ms ease,
        background-color 220ms ease,
        border-color 220ms ease;
}

.site-nav.is-condensed {
    min-height: 48px;
    border-color: rgba(255, 255, 255, 0.16);
    padding-top: 5px;
    padding-bottom: 5px;
    background: rgba(8, 10, 18, 0.78);
}

.site-nav.is-hidden {
    transform: translateX(-50%) translateY(calc(-100% - 24px));
}

.nav-mark {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0;
    background: transparent;
    font-size: 0.86rem;
    font-weight: 800;
    white-space: nowrap;
    text-transform: uppercase;
}

.nav-links {
    display: flex;
    gap: 4px;
    align-items: center;
}

.nav-links a {
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    padding: 10px 13px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
}

.nav-links a:hover,
.nav-links a.is-active {
    border-color: rgba(255, 255, 255, 0.22);
    background: var(--white);
    color: var(--ink);
}

.hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: var(--charcoal);
}

.hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 74%;
    transform: translateY(var(--hero-shift)) scale(var(--hero-zoom));
    transform-origin: center center;
    transition: transform 80ms linear;
    will-change: transform;
}

.hero-shade {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(90deg, rgba(0, 0, 0, 0.76) 0%, rgba(0, 0, 0, 0.38) 34%, rgba(0, 0, 0, 0.06) 70%),
        linear-gradient(0deg, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0) 46%);
}

.hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-image:
        repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.04) 0 1px, transparent 1px 5px),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 7px);
    mix-blend-mode: overlay;
    pointer-events: none;
}

.hero-copy {
    position: absolute;
    left: max(24px, 5vw);
    bottom: 58px;
    z-index: 2;
    width: min(980px, calc(100% - 48px));
    color: var(--white);
}

.hero-kicker,
.eyebrow {
    margin: 0 0 16px;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    overflow-wrap: anywhere;
}

.hero h1 {
    margin: 0;
    font-size: 6.5rem;
    line-height: 0.9;
    font-weight: 900;
}

.hero-role {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin: 24px 0 0;
    font-size: 1.05rem;
    font-weight: 800;
}

.role-label {
    color: var(--acid);
}

.role-dynamic {
    display: inline-flex;
    min-width: 230px;
    min-height: 42px;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    padding: 8px 16px;
    transition: opacity 180ms ease, transform 180ms ease;
}

.role-dynamic.is-changing {
    opacity: 0;
    transform: translateY(8px);
}

.hero-scroll {
    position: absolute;
    right: max(20px, 4vw);
    bottom: 26px;
    z-index: 3;
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
}

.hero-scroll::after {
    display: inline-block;
    width: 44px;
    height: 1px;
    margin-left: 10px;
    background: currentColor;
    content: "";
    vertical-align: middle;
}

.reel-section {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: var(--ink);
    color: var(--white);
    isolation: isolate;
}

.reel-video {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: saturate(0.82) contrast(1.08);
    transform: translateY(var(--reel-shift)) scale(var(--reel-zoom));
    transform-origin: center center;
    transition: transform 80ms linear;
}

.reel-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
        linear-gradient(90deg, rgba(8, 10, 18, 0.84), rgba(8, 10, 18, 0.18) 48%, rgba(8, 10, 18, 0.72)),
        linear-gradient(0deg, rgba(8, 10, 18, 0.88), transparent 45%, rgba(41, 71, 255, 0.22));
    pointer-events: none;
}

.reel-copy {
    position: absolute;
    left: max(24px, calc((100vw - 1240px) / 2));
    bottom: 84px;
    width: min(780px, calc(100% - 48px));
}

.reel-copy .eyebrow {
    color: var(--blue);
}

.reel-copy h2 {
    margin: 0;
    font-size: 6rem;
    line-height: 0.9;
    font-weight: 900;
}

.reel-copy p:not(.eyebrow) {
    max-width: 430px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1rem;
}

.reel-next {
    position: absolute;
    right: max(24px, calc((100vw - 1240px) / 2));
    bottom: 34px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    padding: 10px 15px;
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    background: rgba(8, 10, 18, 0.42);
    backdrop-filter: blur(12px);
}

.section {
    position: relative;
    min-height: 100svh;
    padding: 108px 24px;
    isolation: isolate;
}

.chapter::before {
    position: absolute;
    right: -0.04em;
    bottom: 0.08em;
    z-index: -1;
    color: var(--chapter-accent);
    content: attr(data-watermark);
    font-size: 12rem;
    font-weight: 900;
    line-height: 0.78;
    opacity: 0;
    text-transform: uppercase;
    transform: translateX(8%) translateY(12%);
    transition: opacity 500ms ease, transform 700ms ease, color 260ms ease;
    white-space: nowrap;
    pointer-events: none;
}

.chapter {
    overflow: hidden;
}

.chapter.is-current::before {
    opacity: 0.09;
    transform: translateX(0) translateY(12%);
}

.cinema-section.chapter::before,
.contact-section.chapter::before {
    display: none;
}

.intro-section,
.selected-section,
.journal-section {
    background: var(--paper);
}

.intro-section {
    position: relative;
    display: flex;
    overflow: hidden;
    align-items: center;
}

.intro-grid,
.thinking-layout {
    display: grid;
    width: min(1120px, 100%);
    margin: 0 auto;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 64px;
    align-items: start;
}

.intro-grid h2,
.section-heading h2,
.archive-block h2,
.thinking-layout h2,
.contact-section h2,
.cinema-left h2 {
    margin: 0;
    font-size: 3.8rem;
    line-height: 0.98;
    font-weight: 900;
}

.intro-copy p,
.section-heading p,
.project-card p,
.archive-grid p,
.process-list p,
.craft-grid p {
    margin: 0;
    color: var(--muted);
}

.intro-copy {
    font-size: 1.1rem;
}

.stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 40px;
    background: var(--line);
    border: 1px solid var(--line);
}

.stat-row div {
    min-height: 116px;
    padding: 18px;
    background: var(--paper);
}

.stat-row strong,
.stat-row span {
    display: block;
}

.stat-row strong {
    font-size: 1.9rem;
    line-height: 1;
}

.stat-row span {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
}

.kinetic-strip {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 34px;
    display: flex;
    width: max-content;
    color: rgba(16, 16, 16, 0.16);
    font-size: 4.4rem;
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
    animation: stripMove 26s linear infinite;
    pointer-events: none;
}

.kinetic-strip span {
    padding-right: 18px;
}

@keyframes stripMove {
    from {
        transform: translateX(0);
    }

    to {
        transform: translateX(-50%);
    }
}

.mobile-section {
    background: var(--charcoal);
    color: var(--white);
}

.cinema-section {
    position: relative;
    min-height: 500svh;
    overflow: visible;
    background:
        linear-gradient(120deg, rgba(255, 255, 255, 0.05), transparent 34%),
        var(--charcoal);
}

.cinema-sticky {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: grid;
    min-height: 100svh;
    grid-template-columns: minmax(0, 0.85fr) minmax(320px, 390px) minmax(0, 0.95fr);
    gap: 52px;
    align-items: center;
    overflow: visible;
    opacity: 0;
    padding: 86px max(24px, calc((100vw - 1120px) / 2)) 42px;
    pointer-events: none;
    transition: opacity 180ms ease;
    visibility: hidden;
}

.cinema-section.is-cinema-active .cinema-sticky {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
}

.cinema-bg-word {
    position: absolute;
    left: -12px;
    bottom: -28px;
    z-index: -1;
    color: var(--scene);
    font-size: 15rem;
    font-weight: 900;
    line-height: 0.75;
    opacity: 0.12;
    text-transform: uppercase;
    white-space: nowrap;
    transition: opacity 220ms ease, transform 220ms ease, color 220ms ease;
}

.cinema-left {
    align-self: start;
    padding-top: 8svh;
}

.cinema-left .eyebrow {
    color: var(--scene);
}

.cinema-left h2 {
    font-size: 4.6rem;
    color: var(--white);
}

.cinema-left p:last-child {
    max-width: 360px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.68);
}

.phone-frame {
    position: relative;
    width: min(390px, 100%);
    aspect-ratio: 9 / 16;
    margin: 0 auto;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: #070707;
    box-shadow: var(--shadow), 0 0 58px color-mix(in srgb, var(--scene) 30%, transparent);
    transition: box-shadow 220ms ease, transform 220ms ease, border-color 220ms ease;
}

.phone-frame::before {
    position: absolute;
    top: 7px;
    left: 50%;
    width: 78px;
    height: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.36);
    content: "";
    transform: translateX(-50%);
}

.phone-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 6px;
    background: #000;
}

.cinema-info {
    align-self: end;
    border-left: 1px solid color-mix(in srgb, var(--scene) 52%, transparent);
    padding: 0 0 4svh 24px;
    transition: opacity 180ms ease, transform 180ms ease;
}

.panel-index {
    margin: 0 0 18px;
    color: var(--scene);
    font-size: 0.8rem;
    font-weight: 900;
    text-transform: uppercase;
}

.cinema-info h3 {
    margin: 0;
    color: var(--white);
    font-size: 3.4rem;
    line-height: 1;
    font-weight: 900;
    overflow-wrap: anywhere;
}

.cinema-info > p:not(.panel-index) {
    max-width: 460px;
    margin: 20px 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.05rem;
}

.cinema-info.is-switching,
.cinema-phone.is-switching,
.cinema-bg-word.is-switching {
    opacity: 0.28;
    transform: translateY(12px) scale(0.98);
}

.category-pill,
.tag {
    display: inline-flex;
    width: fit-content;
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 7px 12px;
    color: var(--scene);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
}

.cinema-dots {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin-top: 34px;
}

.cinema-dot {
    position: relative;
    display: grid;
    gap: 6px;
    min-width: 0;
    padding: 0;
    overflow: visible;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    background: transparent;
    color: rgba(255, 255, 255, 0.62);
    cursor: pointer;
    text-align: left;
}

.cinema-dot img {
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: 5px;
    object-fit: cover;
    opacity: 0.58;
    transition: opacity 180ms ease, transform 180ms ease;
}

.cinema-dot span {
    min-height: 24px;
    overflow: hidden;
    font-size: 0.62rem;
    font-weight: 900;
    line-height: 1.1;
    text-overflow: ellipsis;
    text-transform: uppercase;
}

.cinema-dot.active {
    border-color: var(--scene);
    color: var(--scene);
}

.cinema-dot.active img,
.cinema-dot:hover img {
    opacity: 1;
    transform: scale(1.04);
}

.story-steps {
    position: relative;
    z-index: 20;
    pointer-events: none;
}

.story-step {
    display: flex;
    min-height: 100svh;
    align-items: flex-end;
    padding: 0 max(24px, calc((100vw - 1120px) / 2)) 9svh;
}

.step-card {
    width: min(360px, 100%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    padding: 20px;
    background: rgba(12, 12, 12, 0.72);
    color: var(--white);
    opacity: 0.34;
    transform: translateY(34px);
    transition: opacity 300ms ease, transform 300ms ease, border-color 300ms ease;
    backdrop-filter: blur(12px);
}

.story-step.active .step-card {
    border-color: color-mix(in srgb, var(--scene) 70%, transparent);
    opacity: 1;
    transform: translateY(0);
}

.step-card span {
    color: var(--scene);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
}

.step-card h3 {
    margin: 16px 0 10px;
    font-size: 1.35rem;
    line-height: 1.05;
}

.step-card p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
}

.section-heading {
    width: min(1120px, 100%);
    margin: 0 auto 46px;
}

.section-heading.compact {
    display: grid;
    grid-template-columns: 0.42fr 1fr;
    gap: 40px;
    align-items: start;
}

.craft-section {
    display: flex;
    min-height: 100svh;
    flex-direction: column;
    justify-content: center;
    background: var(--paper-soft);
}

.craft-grid {
    display: grid;
    width: min(1120px, 100%);
    margin: 48px auto 0;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
}

.craft-grid article {
    position: relative;
    min-height: 250px;
    overflow: hidden;
    padding: 24px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
}

.craft-grid article::before,
.process-list article::before,
.journal-list a::before {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 3px;
    background: var(--chapter-accent);
    content: "";
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 520ms ease;
}

.craft-grid article.is-visible::before,
.process-list article.is-visible::before,
.journal-list a.is-visible::before {
    transform: scaleX(1);
}

.craft-grid span,
.process-list span {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 900;
}

.craft-grid h3,
.process-list h3,
.archive-grid h3,
.project-card h3 {
    margin: 18px 0 10px;
    font-size: 1.35rem;
    line-height: 1.05;
}

.project-grid {
    display: grid;
    width: min(1120px, 100%);
    margin: 0 auto;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--white);
    transform-origin: center bottom;
}

.project-card:nth-child(odd).is-visible {
    transform: rotate(-1deg);
}

.project-card:nth-child(even).is-visible {
    transform: rotate(1deg);
}

.project-card img {
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: #ddd;
}

.project-card div {
    padding: 18px;
}

.project-card .tag {
    color: var(--blue);
}

.archive-block {
    display: grid;
    width: min(1120px, 100%);
    margin: 96px auto 0;
    grid-template-columns: 0.72fr 1.28fr;
    gap: 40px;
    align-items: start;
}

.archive-block h2 {
    font-size: 2.7rem;
}

.archive-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.archive-grid article {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 14px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.62);
}

.archive-grid img {
    width: 92px;
    aspect-ratio: 1;
    border-radius: 6px;
    object-fit: cover;
    filter: saturate(0.72);
}

.archive-grid h3 {
    margin: 0 0 6px;
    font-size: 1rem;
}

.archive-grid p {
    font-size: 0.9rem;
}

.thinking-section {
    display: flex;
    min-height: 100svh;
    align-items: center;
    background: var(--ink);
    color: var(--white);
}

.thinking-layout .eyebrow {
    color: var(--acid);
}

.process-list {
    display: grid;
    gap: 1px;
    background: rgba(255, 255, 255, 0.14);
}

.process-list article {
    position: relative;
    min-height: 138px;
    overflow: hidden;
    padding: 24px;
    background: var(--ink);
}

.process-list p {
