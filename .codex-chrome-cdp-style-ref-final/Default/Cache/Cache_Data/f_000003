.journal-list {
    display: grid;
    width: min(1120px, 100%);
    margin: 42px auto 0;
    border-top: 1px solid var(--line);
}

.journal-list a {
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 26px 0;
    border-bottom: 1px solid var(--line);
}

.journal-list span {
