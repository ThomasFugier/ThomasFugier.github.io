    position: absolute;
    z-index: -1;
    right: -0.04em;
    bottom: 0.04em;
    left: -0.04em;
    height: 0.2em;
    background: linear-gradient(90deg, rgba(41, 71, 255, 0.3), rgba(41, 71, 255, 0.05));
