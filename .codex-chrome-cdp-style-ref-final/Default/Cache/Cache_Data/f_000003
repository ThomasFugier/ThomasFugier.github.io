/* Reduced art-direction palette: electric blue, off-white, black. */
:root {
    --ink: #080a12;
    --paper: #f7f8ff;
    --paper-soft: #e8ecff;
    --muted: #666d80;
    --line: rgba(8, 10, 18, 0.15);
    --white: #ffffff;
    --charcoal: #080a12;
    --accent: #2947ff;
    --acid: #2947ff;
    --blue: #2947ff;
    --blue-soft: #edf1ff;
    --blue-deep: #07124a;
    --scene: #2947ff;
    --chapter-accent: #2947ff;
}

body {
    background: var(--paper);
}

.scroll-meter span,
.craft-grid article::before,
.process-list article::before,
.journal-list a::before {
    background: var(--blue);
}

.role-label,
.intro-section .eyebrow,
.intro-section .stat-row strong,
.selected-section .eyebrow,
.thinking-layout .eyebrow,
.journal-section .eyebrow,
.category-pill,
.tag,
.panel-index {
    color: var(--blue);
}

.intro-section {
    background:
        linear-gradient(115deg, rgba(41, 71, 255, 0.26), transparent 36%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 44%),
        var(--ink);
}

.cinema-section {
    background:
        linear-gradient(140deg, rgba(41, 71, 255, 0.2), transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 48%),
        var(--ink);
}

.phone-frame {
    box-shadow: var(--shadow), 0 0 58px rgba(41, 71, 255, 0.34);
}

.craft-section {
    background: var(--paper-soft);
}

.craft-grid article:nth-child(1) {
    background: var(--white);
}

.craft-grid article:nth-child(2) {
    background: var(--blue);
    color: var(--white);
}

.craft-grid article:nth-child(2) p,
.craft-grid article:nth-child(4) p {
    color: rgba(255, 255, 255, 0.72);
}

.craft-grid article:nth-child(3) {
    background: var(--blue-soft);
}

.craft-grid article:nth-child(4) {
    background: var(--ink);
    color: var(--white);
}

.selected-section {
    min-height: 118svh;
    background:
        linear-gradient(180deg, rgba(8, 10, 18, 0.24), transparent 36%),
        var(--blue);
}

.selected-section .section-heading {
    margin-bottom: 12svh;
    mix-blend-mode: normal;
}

.selected-section .eyebrow,
.selected-section .section-heading h2 {
    color: var(--white);
}

.project-card {
    border-color: rgba(255, 255, 255, 0.3);
    background: var(--ink);
}

.project-card img {
    opacity: 0.88;
    filter: saturate(0.28) contrast(1.08);
}

.project-card::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(41, 71, 255, 0.08), rgba(8, 10, 18, 0.18));
    content: "";
    mix-blend-mode: screen;
    pointer-events: none;
}

.project-card div {
    z-index: 1;
}

.project-card .tag {
    color: var(--white);
}

.vr-section {
    min-height: 135svh;
    padding: 112px max(24px, calc((100vw - 1240px) / 2)) 120px;
    background:
        linear-gradient(90deg, rgba(41, 71, 255, 0.08), transparent 32%),
        var(--paper);
    color: var(--ink);
}

.vr-section.chapter::before {
    color: var(--blue);
    opacity: 0.08;
}

.vr-heading {
    display: grid;
    width: 100%;
    grid-template-columns: 0.28fr minmax(0, 0.92fr) minmax(260px, 0.44fr);
    gap: 42px;
    align-items: end;
    margin-bottom: 74px;
}

.vr-heading h2 {
    margin: 0;
    max-width: 880px;
    font-size: 5.7rem;
    line-height: 0.9;
    font-weight: 900;
}

.vr-heading > p:last-child {
    margin: 0;
    color: var(--muted);
    font-size: 1.02rem;
}

.vr-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.8fr);
    gap: 18px;
}

.vr-card {
    position: relative;
    min-height: 260px;
    overflow: hidden;
    border: 1px solid rgba(8, 10, 18, 0.18);
    border-radius: 8px;
    background: var(--ink);
    color: var(--white);
    box-shadow: 0 24px 80px rgba(8, 10, 18, 0.16);
}

.vr-card-large {
    min-height: 76svh;
    grid-row: span 3;
}

.vr-card img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    opacity: 0.86;
    filter: saturate(0.42) contrast(1.1);
    transition: transform 420ms ease, filter 420ms ease, opacity 420ms ease;
}

.vr-card:hover img {
    opacity: 0.96;
    filter: saturate(0.78) contrast(1.08);
    transform: scale(1.035);
}

.vr-card div {
    position: absolute;
    inset: auto 0 0;
    padding: 22px;
    background:
        linear-gradient(180deg, transparent, rgba(8, 10, 18, 0.92)),
        linear-gradient(90deg, rgba(41, 71, 255, 0.18), transparent);
}

.vr-card span {
    display: inline-flex;
    margin-bottom: 14px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    padding: 7px 12px;
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
}

.vr-card h3 {
    margin: 0 0 8px;
    font-size: 2rem;
    line-height: 1;
}

.vr-card p {
    max-width: 640px;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
}

.vr-card:not(.vr-card-large) h3 {
    font-size: 1.45rem;
}

.vr-card.is-visible {
    transform: translateY(0);
}

.thinking-section {
    background:
        linear-gradient(135deg, rgba(41, 71, 255, 0.11), transparent 36%),
        var(--paper);
}

.thinking-layout .eyebrow,
.process-list span {
    color: var(--blue);
}

.process-list article {
    border-color: rgba(41, 71, 255, 0.34);
}

.process-list article.is-visible,
.process-list article:hover {
    background: rgba(41, 71, 255, 0.08);
}

.journal-section {
    background: var(--blue);
}

.journal-list a:hover {
    background: var(--white);
    color: var(--ink);
}

.contact-section {
    background: var(--blue);
    color: var(--white);
}

.contact-section::after {
    color: rgba(255, 255, 255, 0.16);
}

.contact-link {
    background: var(--white);
    color: var(--blue);
}

.chapter.is-current .vr-heading h2 {
    animation: sceneTitleIn 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

@media (max-width: 980px) {
    .vr-heading,
    .vr-grid {
        grid-template-columns: 1fr;
    }

    .vr-heading h2 {
        font-size: 4rem;
    }

    .vr-card-large {
        min-height: 58svh;
    }
}

@media (max-width: 680px) {
    .selected-section {
        min-height: 100svh;
    }

    .vr-section {
        min-height: auto;
        padding: 82px 18px;
    }

    .vr-heading {
        width: min(354px, 100%);
        margin: 0 auto 34px;
        gap: 22px;
    }

    .vr-heading h2 {
        font-size: 2.45rem;
        line-height: 0.98;
    }

    .vr-grid {
        width: min(354px, 100%);
        margin: 0 auto;
    }

    .vr-card,
    .vr-card-large {
        min-height: 330px;
    }

    .vr-card h3,
    .vr-card:not(.vr-card-large) h3 {
        font-size: 1.35rem;
    }
}

/* Apple-like mobile lab: fewer panels, more visual focus. */
.cinema-section {
